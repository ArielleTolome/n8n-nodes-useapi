{
  "name": "n8n-nodes-useapi-net",
  "version": "0.6.8",
  "description": "n8n community nodes for useapi.net - AI generation services (Midjourney, Dreamina, Kling, Runway, PixVerse, MiniMax, GoogleFlow, InsightFaceSwap, Mureka, TemPolor)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "useapi",
    "midjourney",
    "dreamina",
    "kling",
    "runway",
    "pixverse",
    "minimax",
    "google-flow",
    "veo",
    "imagen",
    "ai",
    "image-generation",
    "video-generation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ArielleTolome/n8n-nodes-useapi#readme",
  "author": {
    "name": "Ariel"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArielleTolome/n8n-nodes-useapi.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test": "jest"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/UseApiCredentials.credentials.js"
    ],
    "nodes": [
      "dist/nodes/UseApi/UseApi.node.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/express": "^4.17.6",
    "@types/jest": "^29.5.14",
    "@types/request-promise-native": "^1.0.18",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "n8n-workflow": "*",
    "ts-jest": "^29.4.6",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^n8n-workflow$": "<rootDir>/node_modules/n8n-workflow"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": false
          }
        }
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
